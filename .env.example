# Copy this file to .env and fill in real values. .env is gitignored -- never commit it.

# Gmail App Password (not your regular password) -- used to actually send
# the demo "fine" notification email. If left unset, the pipeline just logs
# the mock email content instead of sending it for real.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Where the real demo email gets sent -- this system never looks up a real
# vehicle owner's address, so this should be a demo inbox you control.
DEMO_NOTIFY_EMAIL=memitoscorado@gmail.com
